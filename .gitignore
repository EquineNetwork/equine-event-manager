.DS_Store
*/.DS_Store
en-event-manager-*.zip
equine-event-manager-*.zip

# Composer — runtime deps ARE committed (C11) so the plugin is self-contained
# and deployable without a build step. `composer install --no-dev` regenerates
# vendor/ from composer.lock. Dev tooling (phpcs) is excluded via --no-dev.
composer.phar

# phpcs cache (C6.5.B) — populated by `composer run lint`.
.phpcs-cache

# Editor / OS noise.
*.swp
*.swo
.idea/
.vscode/

# Local logs and scratch.
*.log
.scratch/

# Local dev DB snapshots / fixtures — contain customer data, never commit
.dev-fixtures/

# OPcache-reset dev helper (written transiently by the deploy workflow, self-deletes
# on curl). Must never ship to installs — to a reviewer it reads like a backdoor.
_eem_oc.php
