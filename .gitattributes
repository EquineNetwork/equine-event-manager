.DS_Store export-ignore
admin/.DS_Store export-ignore
docs/ export-ignore
*.zip export-ignore

# Keep dev-only paths out of the archive GitHub serves for branch downloads —
# this is the zip the in-WordPress auto-updater (EEM_Updater / PUC) installs, so
# it must be runtime-only. Root-anchored so vendor/ and the bundled
# plugin-update-checker are never touched.
/.mockups/ export-ignore
/tests/ export-ignore
/scripts/ export-ignore
/tools/ export-ignore
/.claude/ export-ignore
/.github/ export-ignore
# 3.1: strip ALL root markdown from the shipped zip — internal audits/handoffs
# (PAYMENT-CALC-AUDIT, SHIP-READINESS-AUDIT, HEALTH, FOR-REVIEW, CHARGE-CHECKLIST,
# SESSION-HANDOFF, HANDOFF-EEM-STYLING, README, ROADMAP, CLAUDE, CLEANUP, …) never
# belong in a customer install. The plugin reads no .md at runtime; the .org
# readme.txt (when authored) is .txt, not .md, so it ships fine.
/*.md export-ignore
/composer.json export-ignore
/composer.lock export-ignore
/phpcs.xml export-ignore
/.gitattributes export-ignore
/.gitignore export-ignore
