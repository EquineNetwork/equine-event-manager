{
    "name": "whitneymitchell/equine-event-manager",
    "description": "WordPress plugin for equine event reservations — stall, RV, and add-on bookings with multi-event support.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Whitney Mitchell"
        }
    ],
    "support": {
        "source": "https://example.com/equine-event-manager",
        "issues": "https://example.com/equine-event-manager/issues"
    },
    "require": {
        "php": ">=7.4",
        "composer/installers": "^1.12 || ^2.0",
        "dompdf/dompdf": "^2.0",
        "pelago/emogrifier": "^7.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "scripts": {
        "lint": "phpcs",
        "lint:summary": "phpcs --report=summary",
        "lint:fix": "phpcbf",
        "test": "bash tests/smoke/run-all.sh"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "7.4.0"
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
